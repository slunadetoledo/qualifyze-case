  create view "qualifyze_dw"."public_silver"."silver_users__dbt_tmp"
    
    
  as (
    

with source as (
    -- Asumimos que los datos vienen de una tabla 'raw_users' en la capa bronze
    select * from "qualifyze_dw"."bronze"."raw_users"
),

renamed_and_casted as (
    select
        -- Identificadores
        cast(id as integer) as user_id,
        
        -- Información personal (limpieza de espacios y normalización de email)
        trim(cast(first_name as varchar)) as first_name,
        trim(cast(last_name as varchar)) as last_name,
        lower(trim(cast(email as varchar))) as email,
        
        -- Estado y atributos
        cast(is_active as boolean) as is_active,
        
        -- Auditoría y fechas
        cast(created_at as timestamp) as created_at,
        cast(updated_at as timestamp) as updated_at,
        
        -- Metadatos de ingesta (asumiendo que sigues el mismo patrón)
        _ingested_at
    from source
),

deduplicated_users as (
    select
        *,
        -- Nos quedamos con la versión más reciente del usuario en caso de que 
        -- haya actualizaciones duplicadas en la tabla raw
        row_number() over (
            partition by user_id
            order by updated_at desc
        ) as rn
    from renamed_and_casted
)

select
    user_id,
    first_name,
    last_name,
    email,
    is_active,
    created_at,
    updated_at,
    _ingested_at
from deduplicated_users
where rn = 1
  );
