  (
    

with staging as (
    select * from "qualifyze_dw"."public_silver"."stg_eudragmdp"
),

ncr_reports as (
    select
        document_reference_number,
        document_type,
        oms_location_id,
        duns_number,
        site_name,
        issue_date,
        _ingested_at
    from staging
    -- Filtrar solo los reportes de no cumplimiento (NCR)
