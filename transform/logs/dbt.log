  create view "qualifyze_dw"."public_silver"."assert_stg_eudragmdp_uniqueness__dbt_tmp"
    
    
  as (
    -- This test ensures that the deduplication logic in the staging model is working correctly.
-- Because the deduplication partitions by coalesce(document_reference_number, certificate_number),
-- there should be no duplicates of this logical primary key in the final output.

with duplicates as (
    select
        coalesce(document_reference_number, certificate_number) as logical_pk,
        count(*) as cnt
    from "qualifyze_dw"."public_silver"."stg_eudragmdp"
    where coalesce(document_reference_number, certificate_number) is not null
    group by 1
    having count(*) > 1
)

select * from duplicates
  );
